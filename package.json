{
  "name": "nogamble-extension",
  "version": "0.3.5",
  "description": "NoGamble — hides gambling-promoting streamers and categories from Twitch and Kick",
  "scripts": {
    "dev": "wxt dev --browser edge",
    "build": "wxt build --browser chrome",
    "build:edge": "wxt build --browser edge",
    "build:firefox": "wxt build --browser firefox --mv3",
    "zip": "wxt zip --browser chrome",
    "zip:edge": "wxt zip --browser edge",
    "zip:firefox": "wxt zip --browser firefox --mv3",
    "type-check": "tsc --noEmit",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "typescript": "^6.0.3",
    "wxt": "0.20.25"
  },
  "overrides": {
    "minimatch": "^10.0.1",
    "tar": "^7.5.13"
  }
}
